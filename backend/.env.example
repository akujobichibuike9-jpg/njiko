PORT=4000
NODE_ENV=development

# Supabase Postgres connection string.
# Get it from Supabase: Project Settings -> Database -> Connection string -> URI
# Prefer the "Session pooler" or direct URI for a long-running server.
# Copy this file to .env and paste your real string there. Keep .env out of git.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres

# Secret used to sign login tokens — set any long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Only set PGSSL=false if you point at a local non-SSL Postgres.
# REDIS_URL=redis://localhost:6379   # added later for dispatch
